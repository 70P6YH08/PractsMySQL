<Window x:Class="pr18.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pr18"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <Label Content="{Binding Source={x:Static local:DataAccessLayer.connectionString}}"/>
        <Button Content="Авторизация" Width="100" Click="Button_Click"/>
        <Button Content="Запрос" Width="100" Click="Query_Button_Click"/>
    </StackPanel>
</Window>
