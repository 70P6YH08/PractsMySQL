<Window x:Class="pr18.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pr18"
        mc:Ignorable="d"
        Title="AuthorizationWindow" Height="450" Width="800">
    <StackPanel HorizontalAlignment="Center" Width="200" VerticalAlignment="Center">
        <Label Content="Логин"/>
        <TextBox x:Name="LoginTextBox"/>
        <Label Content="Пароль"/>
        <TextBox  x:Name="PasswordTextBox"/>
        <Button Content="Войти" Click="Authorization_Button_Click"/>
    </StackPanel>
</Window>
